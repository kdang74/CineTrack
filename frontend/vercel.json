{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": ""
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://cinetrack-1544.onrender.com/api/:path*" },
    { "source": "/signin-google", "destination": "https://cinetrack-1544.onrender.com/signin-google" },
    { "source": "/hubs/:path*", "destination": "https://cinetrack-1544.onrender.com/hubs/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
